{
  "name": "brieftrack",
  "version": "1.0.0",
  "description": "Brief compliance & program-drift tracker for architects — with a scale-accurate, image-aware bubble diagram.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "architecture",
    "space-planning",
    "bubble-diagram",
    "area-schedule",
    "brief-compliance",
    "react",
    "express",
    "sqlite"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/brieftrack.git"
  },
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node server/index.js",
    "dev:web": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "test": "node --test"
  },
  "dependencies": {
    "express": "^4.19.2",
    "jspdf": "^4.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "vite": "^5.4.0"
  }
}
